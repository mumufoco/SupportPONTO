#--------------------------------------------------------------------
# SupportPONTO .env.example — pacote 456
# Use este arquivo como referência. O instalador gera o .env real com
# segredos aleatórios e NÃO grava senha temporária administrativa.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# AMBIENTE
#--------------------------------------------------------------------
APP_ENV = production
CI_ENVIRONMENT = production
APP_DEBUG = false
CI_DEBUG = false
KINT_ENABLED = false

#--------------------------------------------------------------------
# APLICAÇÃO
#--------------------------------------------------------------------
app.baseURL = 'https://ponto.supportsondagens.com.br/'
app.allowedHostnames = 'ponto.supportsondagens.com.br'
app.indexPage = ''
app.appTimezone = 'America/Sao_Paulo'
app.defaultLocale = 'pt-BR'
app.supportedLocales = 'pt-BR'
app.proxyIPs =
app.forceGlobalSecureRequests = true
app.enforceHttpsSchemeInBaseURL = true
app.cookieSecure = true
app.cookieDomain =
APP_BASE_URL = 'https://ponto.supportsondagens.com.br/'
APP_URL = 'https://ponto.supportsondagens.com.br/'
APP_ALLOWED_HOSTNAMES = 'ponto.supportsondagens.com.br'
APP_TIMEZONE = 'America/Sao_Paulo'
APP_DEFAULT_LOCALE = 'pt-BR'
APP_SUPPORTED_LOCALES = 'pt-BR'
APP_PROXY_IPS =
APP_FORCE_GLOBAL_SECURE_REQUESTS = true
APP_ENFORCE_HTTPS_SCHEME_IN_BASE_URL = true

#--------------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL obrigatório
#--------------------------------------------------------------------
database.default.hostname = '127.0.0.1'
database.default.database = 'supportponto'
database.default.username = 'supportponto'
database.default.password = 'CHANGE_ME_DATABASE_PASSWORD'
database.default.DBDriver = Postgre
database.default.DBPrefix =
database.default.port = 5432
database.default.charset = utf8
database.default.DBCollat =
DB_HOST = '127.0.0.1'
DB_DATABASE = 'supportponto'
DB_USERNAME = 'supportponto'
DB_PASSWORD = 'CHANGE_ME_DATABASE_PASSWORD'
DB_PORT = 5432
PGHOST = '127.0.0.1'
PGDATABASE = 'supportponto'
PGUSER = 'supportponto'
PGPASSWORD = 'CHANGE_ME_DATABASE_PASSWORD'
PGPORT = 5432
PGBOUNCER_PORT = 6432

# Banco de testes opcional
database.tests.hostname = '127.0.0.1'
database.tests.database = 'supportponto_test'
database.tests.username = 'postgres'
database.tests.password = 'postgres'
database.tests.DBDriver = Postgre
database.tests.port = 5432

#--------------------------------------------------------------------
# SEGREDOS DA APLICAÇÃO
# Gere valores reais no servidor. O instalador cria automaticamente.
#--------------------------------------------------------------------
encryption.key = 'base64:CHANGE_ME_GENERATE_RANDOM_32_BYTES'
ENCRYPTION_KEY = 'base64:CHANGE_ME_GENERATE_RANDOM_32_BYTES'
ENCRYPTION_KEY_VERSION = 1
JWT_SECRET_KEY = 'CHANGE_ME_RANDOM_64_HEX'
QR_SECRET_KEY = 'CHANGE_ME_RANDOM_64_HEX'
DEEPFACE_API_KEY = 'CHANGE_ME_RANDOM_TOKEN'
DEEPFACE_INTERNAL_TOKEN =
HEALTH_DETAILS_TOKEN =
INSTALLER_TOKEN =
INSTALLER_ALLOWED_IPS =
INSTALLER_PRODUCTION_WEB_OVERRIDE = false
INSTALLER_REINSTALL_TOKEN =
INSTALLER_RESET_TOKEN =

# Não persistir senha inicial administrativa.
ADMIN_INITIAL_NAME = 'Administrador do Sistema'
ADMIN_INITIAL_EMAIL = 'admin@supportsondagens.com.br'
ADMIN_INITIAL_CPF =
ADMIN_INITIAL_PASSWORD_OUTPUT =
# ADMIN_INITIAL_PASSWORD deve permanecer ausente/vazio.

#--------------------------------------------------------------------
# SESSÃO, COOKIES E CSRF
#--------------------------------------------------------------------
session.driver = 'CodeIgniter\\Session\\Handlers\\FileHandler'
session.cookieName = 'ponto_session'
session.expiration = 7200
session.savePath = 'writable/session'
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = true
session.cookieSecure = true
session.cookieDomain =
session.cookieSameSite = 'Lax'
session.idleTimeout = 1800
SESSION_DRIVER = 'CodeIgniter\\Session\\Handlers\\FileHandler'
SESSION_COOKIE_NAME = 'ponto_session'
SESSION_EXPIRATION = 7200
SESSION_SAVE_PATH = 'writable/session'
SESSION_MATCH_IP = false
SESSION_TIME_TO_UPDATE = 300
SESSION_REGENERATE_DESTROY = true
cookie.secure = true
cookie.httponly = true
cookie.samesite = 'Lax'
COOKIE_SECURE = true
cookie.domain =
security.csrfProtection = 'session'
security.tokenRandomize = true
security.tokenName = 'csrf_token'
security.headerName = 'X-CSRF-TOKEN'
security.cookieName = 'csrf_cookie_name'
security.expires = 7200
security.regenerate = true
security.stepUpTtl = 900

#--------------------------------------------------------------------
# HEADERS, CSP E HSTS
#--------------------------------------------------------------------
CSP_REPORT_ONLY = true
CSP_UPGRADE_INSECURE_REQUESTS = true
CSP_ALLOW_INLINE_STYLE = true
CSP_ALLOW_INLINE_SCRIPT_ATTR = true
CSP_CONNECT_SRC =
SECURITY_HSTS_ENABLED = false
APP_HSTS_ENABLED = false
SECURITY_HSTS_MAX_AGE = 31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS = true
SECURITY_HSTS_PRELOAD = false

#--------------------------------------------------------------------
# EMPRESA, LGPD E ALERTAS
#--------------------------------------------------------------------
company.name = 'Support Solo Sondagens LTDA'
company.cnpj = '00.000.000/0001-00'
COMPANY_NAME = 'Support Solo Sondagens LTDA'
COMPANY_CNPJ = '00.000.000/0001-00'
DPO_EMAIL = 'dpo@supportsondagens.com.br'
NSR_ALERT_EMAIL = 'contato@supportsondagens.com.br'
ALERT_EMAILS = 'contato@supportsondagens.com.br'
BACKUP_EMAILS = 'contato@supportsondagens.com.br'
LGPD_RETENTION_DAYS = 1825
LGPD_BIOMETRIC_RETENTION_DAYS = 365

#--------------------------------------------------------------------
# E-MAIL / SMS / PUSH
#--------------------------------------------------------------------
email.protocol = 'smtp'
email.fromEmail = 'contato@supportsondagens.com.br'
email.fromName = 'SupportPONTO'
email.SMTPHost = 'smtp.seu-dominio.com.br'
email.SMTPUser = 'usuario@seu-dominio.com.br'
email.SMTPPass = 'CHANGE_ME_SMTP_PASSWORD'
email.SMTPPort = 587
email.SMTPCrypto = 'tls'
email.mailType = 'html'
email.charset = 'utf-8'
SMS_PROVIDER = 'mock'
TWILIO_ACCOUNT_SID =
TWILIO_AUTH_TOKEN =
TWILIO_PHONE_NUMBER =
AWS_ACCESS_KEY_ID =
AWS_SECRET_ACCESS_KEY =
AWS_REGION = 'us-east-1'
FCM_SERVER_KEY =
VAPID_SUBJECT = 'mailto:contato@supportsondagens.com.br'
VAPID_PUBLIC_KEY =
VAPID_PRIVATE_KEY =

#--------------------------------------------------------------------
# CACHE / REDIS
#--------------------------------------------------------------------
cache.handler = file
cache.backupHandler = file
cache.enableRedis = false
cache.requireRedis = false
CACHE_TTL = 300
REDIS_HOST = '127.0.0.1'
REDIS_PORT = 6379
REDIS_PASSWORD =
REDIS_DATABASE = 0
REDIS_TIMEOUT = 2

#--------------------------------------------------------------------
# CORS, RATE LIMIT E API
#--------------------------------------------------------------------
CORS_ALLOWED_ORIGINS = 'https://ponto.supportsondagens.com.br'
CORS_ALLOW_CREDENTIALS = false
RATE_LIMIT_WHITELIST = '127.0.0.1,::1'
RATELIMIT_DEFAULT = '60 per minute'
RATELIMIT_STORAGE_URL =
OAUTH_ACCESS_TOKEN_LIFETIME = 3600
OAUTH_REFRESH_TOKEN_LIFETIME = 2592000

#--------------------------------------------------------------------
# BIOMETRIA — DeepFace e SourceAFIS
#--------------------------------------------------------------------
DEEPFACE_API_URL = 'http://localhost:5000'
DEEPFACE_THRESHOLD = 0.40
DEEPFACE_TIMEOUT = 30
DEEPFACE_RETRY_ATTEMPTS = 2
DEEPFACE_MODEL = 'VGG-Face'
DEEPFACE_DETECTOR = 'opencv'
DEEPFACE_CIRCUIT_BREAKER_ENABLED = true
DEEPFACE_CIRCUIT_FAILURE_THRESHOLD = 3
DEEPFACE_CIRCUIT_OPEN_SECONDS = 120
DEEPFACE_CIRCUIT_HALF_OPEN_AFTER = 120
BIOMETRIC_FACE_MAX_BYTES = 3145728
BIOMETRIC_FACE_MIN_BYTES = 1000
BIOMETRIC_FACE_MAX_PIXELS = 6000000
SOURCEAFIS_MODE = native
SOURCEAFIS_API_URL = 'http://localhost:5001'
SOURCEAFIS_TIMEOUT = 30
SOURCEAFIS_THRESHOLD = 0.40
sourceafis.mode = native
sourceafis.api_url = 'http://localhost:5001'
sourceafis.timeout = 30
sourceafis.threshold = 0.40
biometric.fingerprint.enabled = true
biometric.fingerprint.threshold = 30
biometric.min_quality_score = 30
biometric.max_templates_per_user = 5
biometric.allow_duplicate_check = true
biometric.encryption_enabled = true
BIOMETRIC_ENCRYPTION_ENABLED = true
biometric.audit_all_attempts = true
biometric.rate_limit_attempts = 10
biometric.rate_limit_window = 60
biometric.require_consent = true
biometric.consent_version = 1.0
TWO_FACTOR_ALLOW_EXTERNAL_QR_FALLBACK = false

#--------------------------------------------------------------------
# WEB SOCKET / CHAT
#--------------------------------------------------------------------
WEBSOCKET_HOST = '0.0.0.0'
WEBSOCKET_PORT = 8080
WEBSOCKET_WORKERS = 2
WEBSOCKET_MAX_MESSAGE_BYTES = 65536
WEBSOCKET_ALLOWED_ORIGINS = 'https://ponto.supportsondagens.com.br'

#--------------------------------------------------------------------
# LOGS, MONITORAMENTO E BACKUPS
#--------------------------------------------------------------------
logger.threshold = 4
monitoring.enabled = true
monitoring.alert_email = 'contato@supportsondagens.com.br'
backup.retention_days = 30
backup.notification_email = 'contato@supportsondagens.com.br'
SENTRY_ENABLED = false
SENTRY_DSN_PHP =
SENTRY_DSN_JS =
SENTRY_ENVIRONMENT = production
SENTRY_TRACES_SAMPLE_RATE = 0.1

#--------------------------------------------------------------------
# ASSINATURA / ICP-BRASIL
#--------------------------------------------------------------------
ICP_CERTIFICATE_PATH =
ICP_KEY_PATH =
ICP_KEY_PASSWORD =
ICP_BRASIL_CERT_PATH =
ICP_BRASIL_CERT_PASSWORD =

#--------------------------------------------------------------------
# INSTALADOR E AUTOMAÇÕES CONTROLADAS
#--------------------------------------------------------------------
ALLOW_WEB_INSTALLER = false
SECURITY_PRODUCTION_HARDENING = true
SECURITY_PROTECT_INTERNAL_PATHS = true
PROCESS_ALLOW_CLI_SHELL = true
PROCESS_ALLOW_WEB_SHELL = false
PROCESS_ALLOW_WEB_BINARY_DISCOVERY = false
BACKUP_ALLOW_WEB_RUNTIME = false
INSTALLER_ALLOW_WEB_AUTOMATION = false
INSTALLER_ALLOW_COMPOSER_AUTOMATION = false
INSTALLER_ALLOW_NODE_AUTOMATION = false
INSTALLER_ALLOW_WRITABLE_BOOTSTRAP = false
INSTALLER_ALLOW_FRONTEND_BUILD_AUTOMATION = false
INSTALLER_AUTO_DISABLE_WEB = true
INSTALLER_REQUIRE_LOCK = true
INSTALLER_COMPOSER_BIN = '/usr/local/bin/composer'
INSTALLER_PHP_BIN = '/usr/bin/php'
INSTALLER_NODE_BIN = 'node'
INSTALLER_NPM_BIN = 'npm'
INSTALLER_PROJECT_ROOT =
INSTALLER_AUTOMATION_TIMEOUT = 1800

#--------------------------------------------------------------------
# PROVISIONAMENTO DO SERVIDOR
#--------------------------------------------------------------------
# Diagnóstico: bash install/runtime/provision-server.sh --diagnose
# Provisionamento Ubuntu/aaPanel: sudo bash install/runtime/provision-server.sh --all --project-user=www

# -----------------------------------------------------------------------------
# LGPD / PRIVACIDADE / RETENÇÃO
# -----------------------------------------------------------------------------
DPO_EMAIL=contato@supportsondagens.com.br
LGPD_REQUEST_SLA_DAYS=15
LGPD_RETENTION_EMPLOYEE_DAYS=3650
LGPD_RETENTION_LABOR_DAYS=3650
LGPD_RETENTION_BIOMETRIC_DAYS=180
LGPD_RETENTION_GEOLOCATION_DAYS=730
LGPD_RETENTION_AUDIT_DAYS=1825
LGPD_RETENTION_EXPORT_DAYS=2

#--------------------------------------------------------------------
# FILAS / JOBS ASSÍNCRONOS
#--------------------------------------------------------------------
QUEUE_KNOWN_QUEUES = 'reports,biometric,exports,notifications,maintenance,default'
QUEUE_WORKER_LIMIT = 10
QUEUE_WORKER_SLEEP = 5
QUEUE_WORKER_MEMORY_MB = 256
QUEUE_STALE_AFTER_MINUTES = 15
QUEUE_MAX_PAYLOAD_BYTES = 8388608
QUEUE_TEMP_FILES_TTL_HOURS = 24
QUEUE_RESULT_FILES_TTL_HOURS = 72
