# SupportPONTO — Configuração do deploy único (scripts/release/deploy.sh)
#
# Copie para um arquivo NÃO versionado (ex.: scripts/release/deploy.env.local)
# e ajuste os valores. Use com:
#   scripts/release/deploy.sh --env-file scripts/release/deploy.env.local
#
# NUNCA commite o arquivo preenchido — ele pode conter dados de acesso ao servidor.

DEPLOY_HOST=192.168.31.101
DEPLOY_USER=mumufoco
DEPLOY_PATH=/www/wwwroot/ponto.supportsondagens.com.br
DEPLOY_PHP_BIN=/www/server/php/83/bin/php
DEPLOY_PHP_FPM_SVC=php8.3-fpm
DEPLOY_WEB_USER=www
DEPLOY_SSH_PORT=22
