            "artifact-manifest.json",
            "scripts/release/build-release-package.sh e build-source-package.sh",
            "docs/releases/ARTIFACT_STRATEGY.md (conceito source vs release package)"
        ],
        "manual_fallback_pattern": "SFTP getfo/putfo + sudo cp + chown www:www + systemctl reload php8.3-fpm (documentado para emergências; o script automatiza o ciclo completo)"
    },

    "release_channel": "stable",
