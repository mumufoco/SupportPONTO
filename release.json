        "stages": [
            "package (rsync exclude-list, sem zip intermediário)",
            "transfer (rsync --delete-after via SSH)",
            "install (composer install --no-dev, spark migrate, cache:clear, permissões www:www)",
            "restart (systemctl reload php8.3-fpm; restart do queue worker se existir)"
        ],
        "verification": "scripts/verify-deployment.sh e checagem automática de /health/readiness ao final do deploy.sh",
        "replaces": [
            "docker-compose.yml / docker-compose.*.yml",
