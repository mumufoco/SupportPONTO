# SupportPONTO — .gitignore

# Environment configuration (contains secrets)
.env
.env.*
!.env.example

# Composer dependencies
vendor/
composer.lock

# CodeIgniter writable directory — never commit runtime data
writable/cache/*
writable/composer/*
writable/logs/*
writable/session/*
writable/uploads/*
writable/exports/*
writable/biometric/*
writable/secrets/*
writable/installer/installed.lock

# Keep directory structure for deployment
!writable/cache/.gitkeep
!writable/composer/.gitkeep
!writable/logs/.gitkeep
!writable/session/.gitkeep
!writable/uploads/.gitkeep
!writable/exports/.gitkeep
!writable/biometric/.gitkeep
!writable/secrets/.gitkeep
!writable/installer/.gitkeep

# Gerado dinamicamente por ManifestGeneratorService a cada salvar de
# configurações PWA / upload de ícone — versionar causava conflito no próximo
# git pull do servidor (o arquivo regenerado sempre diverge do committed).
public/manifest.webmanifest

# Node / npm (if any frontend build tools)
node_modules/
npm-debug.log
yarn-error.log

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# IDE artifacts
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# PHP artifacts
*.cache
*.log

# Build artifacts
build/dist/

# Cópias de backup manuais (ex.: Arquivo.php.bak, Arquivo.php.bak_pre_algo_20260101) —
# BAIXO-06 na auditoria: dezenas ficaram versionadas dentro de app/ e ate em public/
# (diretamente acessível pela web). O historico do git ja preserva versoes antigas;
# essas copias nao devem ser commitadas.
*.bak
*.bak[0-9]
*.bak_*
