<?php

namespace App\Services\TXT;

class TXTAFDBuilder
{
    /**
     * @return string[]
     */
    public function buildLines(array $data, array $companyProfile): array
    {
        $lines = [];
        $lines[] = $this->generateHeader();
        $lines[] = $this->generateEmployer($companyProfile);
        $lines[] = $this->generateRep();

        foreach ($data as $record) {
            $lines[] = $this->generatePunch((array) $record);
        }

        $lines[] = $this->generateTrailer(count($data));

        return $lines;
    }

    private function generateHeader(): string
    {
        return sprintf(
            '000000000%s%s%s',
            date('dmYHi'),
            str_pad('1', 12, '0', STR_PAD_LEFT),
            str_pad('1.0', 23, ' ')
        );
    }

    private function generateEmployer(array $companyProfile): string
    {
        $cnpj = preg_replace('/\D/', '', (string) ($companyProfile['companyCNPJ'] ?? '')) ?: '';
        $companyName = (string) ($companyProfile['companyName'] ?? '');
        $companyAddress = (string) ($companyProfile['companyAddress'] ?? '');

        return sprintf(
            '100000001%s%s%s%s',
            str_pad($cnpj, 14, '0', STR_PAD_LEFT),
            str_pad(substr($companyName, 0, 150), 150, ' '),
            str_pad(substr($companyAddress, 0, 100), 100, ' '),
            str_pad('', 80, ' ')
        );
    }

    private function generateRep(): string
    {
        return sprintf(
            '200000001%s%s%s',
            str_pad('1', 12, '0', STR_PAD_LEFT),
            date('dmY'),
            str_pad('REP VIRTUAL SUPPORTPONTO', 100, ' ')
        );
    }

    private function generatePunch(array $record): string
    {
        if (! isset($record['nsr']) || (int) $record['nsr'] < 1) {
            throw new \RuntimeException('Registro de marcacao sem NSR canonico - exportacao de AFD bloqueada por integridade.');
        }
        $nsr = (int) $record['nsr'];

        $pis = isset($record['pis']) ? preg_replace('/\D/', '', (string) $record['pis']) : '00000000000';
        $date = isset($record['date']) ? date('dmY', strtotime((string) $record['date'])) : date('dmY');
        $time = isset($record['punch_time']) ? date('Hi', strtotime((string) $record['punch_time'])) : date('Hi');

        return sprintf(
            '3%s%s%s%s%s',
            str_pad((string) $nsr, 9, '0', STR_PAD_LEFT),
            str_pad($pis ?: '00000000000', 12, '0', STR_PAD_LEFT),
            $date,
            $time,
            str_pad('', 20, ' ')
        );
    }

    private function generateTrailer(int $totalRecords): string
    {
        $totalLines = $totalRecords + 4;

        return sprintf('999999999%s', str_pad((string) $totalLines, 9, '0', STR_PAD_LEFT));
    }
}
