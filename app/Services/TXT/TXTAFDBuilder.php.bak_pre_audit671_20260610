<?php

namespace App\Services\TXT;

/**
 * Gerador do Arquivo Fonte de Dados (AFD) conforme o leiaute oficial da Portaria MTE 671/2021,
 * publicado em:
 * https://www.gov.br/trabalho-e-emprego/pt-br/assuntos/inspecao-do-trabalho/fiscalizacao-do-trabalho/leiaute-do-arquivo-fonte-de-dados-afd.pdf
 *
 * O SupportPONTO opera como REP-P (Registrador Eletrônico de Ponto por Programa — REP virtual
 * baseado em software, conforme identificação "REP VIRTUAL SUPPORTPONTO"). Por isso:
 *
 *   - Os registros de marcação de ponto usam o tipo "7" (exclusivo para REP-P) — e não o tipo
 *     "3", que é exclusivo para REP-C/REP-A (terminais físicos com hardware homologado).
 *   - A identificação do trabalhador é feita exclusivamente por CPF: o PIS deixou de ser aceito
 *     no AFD a partir de 03/04/2024, quando entrou em vigor o leiaute desta portaria.
 *   - O "código hash" do registro tipo "7" usa SHA-256 e é encadeado — cada registro referencia
 *     o hash do registro anterior do mesmo arquivo —, conforme a fórmula descrita no item 9 do
 *     leiaute oficial. Este hash de exportação é calculado neste builder, no momento da geração
 *     do arquivo, e é independente da cadeia de integridade interna gravada em time_punches
 *     (hash/previous_hash/chain_hash), cuja fórmula contempla outros campos para fins de
 *     tamper-evidence do banco de dados.
 *   - Os registros tipo "1" e "2" exigem CRC-16 no padrão CRC-16/KERMIT (CCITT-TRUE), conforme
 *     a observação do item 8 do leiaute — verificável pelo exemplo oficial:
 *     CRC16("123456789") = 0x2189.
 *   - O arquivo deve terminar com um registro de Assinatura Digital. Para REP-P, esse registro é
 *     preenchido com o texto literal "ASSINATURA_DIGITAL_EM_ARQUIVO_P7S" (a assinatura real é
 *     entregue separadamente, em arquivo .p7s).
 *
 * NOTA — registros condicionais (tipos "2", "4", "5" e "6"): estes só existem quando o evento
 * correspondente de fato ocorre (alteração cadastral da empresa, ajuste de relógio do REP,
 * inclusão/alteração/exclusão de empregado, eventos sensíveis do REP).
 *
 * Os tipos "2" (CompanyRecordEventModel), "4" (ClockAdjustmentModel), "5"
 * (EmployeeRecordEventModel) e "6" (RepAvailabilityEventModel) já possuem fontes de dados
 * dedicadas:
 *   - "2"/"4"/"5": declarações conscientes feitas pelo sistema/administrador — "2"/"4" via
 *     telas próprias do painel admin (ver Admin\CompanyRecordEventController /
 *     Admin\ClockAdjustmentController); "5" disparado automaticamente nos pontos de
 *     inclusão/alteração/exclusão de empregado (ver EmployeeAfdEventRecorderService e os
 *     pontos de injeção em EmployeeController/EmployeeControllerActionService/
 *     EmployeeChangeRequestController) — todos armazenados de forma imutável e com NSR
 *     canônico;
 *   - "6": DETECTADO (não declarado) por um heartbeat periódico — o sistema não pode logar
 *     sua própria indisponibilidade enquanto está fora do ar. Ver
 *     App\Services\REP\RepAvailabilityMonitorService / RepHeartbeatCommand para o racional
 *     completo e o mecanismo de detecção por comparação entre execuções.
 *
 * @return string[]
 */
class TXTAFDBuilder
{
    private const RECORD_TYPE_HEADER         = '1';
    private const RECORD_TYPE_COMPANY        = '2';
    private const RECORD_TYPE_CLOCK_ADJUST   = '4';
    private const RECORD_TYPE_EMPLOYEE       = '5';
    private const RECORD_TYPE_REP_EVENT      = '6';
    private const RECORD_TYPE_PUNCH          = '7';
    private const RECORD_TYPE_TRAILER        = '9';

    private const DIGITAL_SIGNATURE_PLACEHOLDER = 'ASSINATURA_DIGITAL_EM_ARQUIVO_P7S';

    /**
     * @param array $data             Registros de marcação de ponto. Cada item deve conter:
     *                                 nsr, cpf, punch_time, created_at, method, user_agent,
     *                                 employee_name (ver ReportExecutionGeneratorsTrait::buildAfdData).
     * @param array $companyProfile   Perfil da empresa/REP — ver TXTSettingsProvider::getCompanyProfile().
     * @param array $clockAdjustments Declarações de ajuste de relógio do REP no período (registro
     *                                tipo "4"). Cada item deve conter: nsr, previous_datetime,
     *                                adjusted_datetime, responsible_cpf — ver
     *                                ClockAdjustmentModel::findInPeriod() /
     *                                ReportExecutionGeneratorsTrait::buildAfdData().
     * @param array $companyEvents    Declarações de alteração cadastral da empresa no período
     *                                (registro tipo "2"). Cada item deve conter: nsr, recorded_at,
     *                                responsible_cpf, employer_doc_type, employer_doc, cno_caepf,
     *                                company_name, service_location — ver
     *                                CompanyRecordEventModel::findInPeriod().
     * @param array $availabilityEvents Eventos sensíveis do REP detectados no período (registro
     *                                tipo "6", códigos "07"/"08"). Cada item deve conter: nsr,
     *                                event_code, recorded_at — ver
     *                                RepAvailabilityEventModel::findInPeriod() /
     *                                RepAvailabilityMonitorService.
     * @param array $employeeEvents   Eventos de inclusão/alteração/exclusão de empregado no
     *                                período (registro tipo "5"). Cada item deve conter: nsr,
     *                                operation_type ("I"/"A"/"E"), employee_cpf, employee_name,
     *                                responsible_cpf, recorded_at — ver
     *                                EmployeeRecordEventModel::findInPeriod() /
     *                                EmployeeAfdEventRecorderService.
     *
     * @return string[]
     */
    public function buildLines(array $data, array $companyProfile, array $clockAdjustments = [], array $companyEvents = [], array $availabilityEvents = [], array $employeeEvents = []): array
    {
        $punchRecords        = $this->buildPunchRecords($data);
        $clockAdjustRecords  = $this->buildClockAdjustRecords($clockAdjustments);
        $companyRecords      = $this->buildCompanyRecords($companyEvents, $companyProfile);
        $availabilityRecords = $this->buildAvailabilityRecords($availabilityEvents);
        $employeeRecords     = $this->buildEmployeeRecords($employeeEvents);

        $lines   = [];
        $lines[] = $this->generateHeader($companyProfile, $data);

        foreach ($companyRecords as $record) {
            $lines[] = $record;
        }

        foreach ($punchRecords as $record) {
            $lines[] = $record;
        }

        foreach ($clockAdjustRecords as $record) {
            $lines[] = $record;
        }

        foreach ($employeeRecords as $record) {
            $lines[] = $record;
        }

        foreach ($availabilityRecords as $record) {
            $lines[] = $record;
        }

        $lines[] = $this->generateTrailer(
            count($companyRecords),
            count($clockAdjustRecords),
            count($employeeRecords),
            count($availabilityRecords),
            count($punchRecords)
        );

        $lines[] = $this->generateDigitalSignature();

        return $lines;
    }

    // ------------------------------------------------------------------------
    // Registro tipo "1" — Cabeçalho (302 caracteres, campos 1 a 15 + CRC-16)
    // ------------------------------------------------------------------------
    private function generateHeader(array $companyProfile, array $data): string
    {
        [$startDate, $endDate] = $this->resolvePeriod($data);

        $employerDocType  = $this->onlyDigits((string) ($companyProfile['companyDocType'] ?? '1')) ?: '1';
        $employerDoc      = $this->onlyDigits((string) ($companyProfile['companyCNPJ'] ?? ''));
        $cnoCaepf         = $this->onlyDigits((string) ($companyProfile['companyCnoCaepf'] ?? ''));
        $companyName      = (string) ($companyProfile['companyName'] ?? '');
        $repIdentifier    = $this->onlyDigits((string) ($companyProfile['inpiRegistration'] ?? '99999999999999999'));
        $developerDocType = $this->onlyDigits((string) ($companyProfile['developerDocType'] ?? '1')) ?: '1';
        $developerDoc     = $this->onlyDigits((string) ($companyProfile['developerCNPJ'] ?? '')) ?: $employerDoc;

        $body =
            $this->padNumeric('000000000', 9)
            . self::RECORD_TYPE_HEADER
            . $this->padNumeric($employerDocType, 1)
            . $this->padNumeric($employerDoc, 14)
            . $this->padNumeric($cnoCaepf, 14)
            . $this->padAlpha($companyName, 150)
            . $this->padNumeric($repIdentifier, 17)
            . $this->formatDate($startDate)
            . $this->formatDate($endDate)
            . $this->formatDateTime('now')
            . $this->padNumeric('003', 3)
            . $this->padNumeric($developerDocType, 1)
            . $this->padNumeric($developerDoc, 14)
            . $this->padAlpha('', 30); // campo 14 (modelo) é exclusivo de REP-C — em branco para REP-P

        return $body . $this->crc16Kermit($body);
    }

    // ------------------------------------------------------------------------
    // Registro tipo "2" — Inclusão/alteração da identificação da empresa no REP
    // (331 caracteres, campos 1 a 9 + CRC-16).
    //
    // Gerado a partir de declarações conscientes de alteração cadastral feitas por um
    // administrador (ver Admin\CompanyRecordEventController / CompanyRecordEventModel —
    // evento raro, no mesmo espírito do ajuste de relógio do tipo "4"). Cada declaração já
    // é um "retrato" dos dados cadastrais vigentes naquele momento — por isso priorizamos
    // os campos do próprio evento (histórico/imutável) e usamos `$companyProfile` (config
    // atual do sistema) apenas como fallback para eventos legados sem o retrato completo.
    // ------------------------------------------------------------------------
    private function generateCompanyRecord(array $event, array $companyProfile): string
    {
        $employerDocType = $this->onlyDigits((string) ($event['employer_doc_type'] ?? $companyProfile['companyDocType'] ?? '1')) ?: '1';
        $employerDoc     = $this->onlyDigits((string) ($event['employer_doc'] ?? $companyProfile['companyCNPJ'] ?? ''));
        $cnoCaepf        = $this->onlyDigits((string) ($event['cno_caepf'] ?? $companyProfile['companyCnoCaepf'] ?? ''));
        $companyName     = (string) ($event['company_name'] ?? $companyProfile['companyName'] ?? '');
        $serviceLocation = (string) ($event['service_location'] ?? $companyProfile['companyAddress'] ?? '');
        $responsibleCpf  = $this->onlyDigits((string) ($event['responsible_cpf'] ?? ''));

        if ($responsibleCpf === '' || strlen($responsibleCpf) > 14) {
            throw new \RuntimeException('Declaração de alteração cadastral sem CPF válido do responsável — exportação de AFD bloqueada.');
        }
        if (! isset($event['nsr']) || (int) $event['nsr'] < 1) {
            throw new \RuntimeException('Declaração de alteração cadastral sem NSR canônico — exportação de AFD bloqueada por integridade.');
        }

        $body =
            $this->padNumeric((string) (int) $event['nsr'], 9)
            . self::RECORD_TYPE_COMPANY
            . $this->formatDateTime((string) ($event['recorded_at'] ?? 'now'))
            . $this->padNumeric($responsibleCpf, 14)
            . $this->padNumeric($employerDocType, 1)
            . $this->padNumeric($employerDoc, 14)
            . $this->padNumeric($cnoCaepf, 14)
            . $this->padAlpha($companyName, 150)
            . $this->padAlpha($serviceLocation, 100);

        return $body . $this->crc16Kermit($body);
    }

    /**
     * @param array $events Declarações de alteração cadastral (registro tipo "2") — cada item
     *                      deve conter: nsr, recorded_at, responsible_cpf, employer_doc_type,
     *                      employer_doc, cno_caepf, company_name, service_location.
     *
     * @return string[]
     */
    private function buildCompanyRecords(array $events, array $companyProfile): array
    {
        $records = [];

        foreach ($events as $event) {
            $records[] = $this->generateCompanyRecord((array) $event, $companyProfile);
        }

        return $records;
    }

    // ------------------------------------------------------------------------
    // Registro tipo "7" — Marcação de ponto para REP-P (137 caracteres, campos 1 a 8)
    // ------------------------------------------------------------------------

    /**
     * @return string[]
     */
    private function buildPunchRecords(array $data): array
    {
        $records      = [];
        $previousHash = '';

        foreach ($data as $record) {
            $record = (array) $record;

            if (! isset($record['nsr']) || (int) $record['nsr'] < 1) {
                throw new \RuntimeException('Registro de marcação sem NSR canônico — exportação de AFD bloqueada por integridade.');
            }

            $cpf = $this->onlyDigits((string) ($record['cpf'] ?? ''));
            if ($cpf === '' || strlen($cpf) > 12) {
                throw new \RuntimeException(
                    'Registro de marcação sem CPF válido do empregado — exportação de AFD bloqueada. '
                    . 'A Portaria MTE 671/2021 exige identificação exclusiva por CPF (o PIS não é mais aceito desde 03/04/2024).'
                );
            }

            $nsr           = (string) (int) $record['nsr'];
            $nsrField      = $this->padNumeric($nsr, 9);
            $punchDateTime = $this->formatDateTime((string) ($record['punch_time'] ?? ''));
            $cpfField      = $this->padNumeric($cpf, 12);
            $recordedAt    = $this->formatDateTime((string) ($record['created_at'] ?? $record['punch_time'] ?? ''));
            $collector     = $this->resolveCollectorIdentifier(
                (string) ($record['method'] ?? ''),
                (string) ($record['user_agent'] ?? '')
            );
            $onlineFlag = ((string) ($record['offline'] ?? '0')) === '1' ? '1' : '0';

            // Fórmula oficial do hash (item 9 do leiaute): NSR + tipo + DH marcação + CPF +
            // DH gravação + coletor + flag on/off-line + hash SHA-256 do registro anterior.
            $hashInput = $nsrField
                . self::RECORD_TYPE_PUNCH
                . $punchDateTime
                . $cpfField
                . $recordedAt
                . $collector
                . $onlineFlag
                . $previousHash;

            $hash         = hash('sha256', $hashInput);
            $previousHash = $hash;

            $records[] =
                $nsrField
                . self::RECORD_TYPE_PUNCH
                . $punchDateTime
                . $cpfField
                . $recordedAt
                . $collector
                . $onlineFlag
                . $this->padAlpha($hash, 64);
        }

        return $records;
    }

    /**
     * Resolve o "identificador do coletor da marcação" (campo nº 6 do registro tipo "7"):
     *   "01" aplicativo mobile · "02" browser · "03" aplicativo desktop ·
     *   "04" dispositivo eletrônico · "05" outro dispositivo não especificado.
     *
     * O SupportPONTO é operado primariamente via painel web (navegador). Na ausência de um
     * aplicativo mobile/desktop nativo dedicado, o padrão adotado é "02" (browser); ajustamos
     * para "01" quando o user-agent indicar claramente um dispositivo móvel. Esta heurística
     * deve ser revisada/expandida caso o sistema passe a operar com app mobile/desktop nativo
     * ou terminais físicos dedicados — nesse caso, o ideal é gravar o identificador do coletor
     * já no momento da marcação (em time_punches), em vez de inferi-lo na exportação.
     */
    private function resolveCollectorIdentifier(string $method, string $userAgent): string
    {
        $ua = mb_strtolower($userAgent);

        if ($ua !== '' && preg_match('/(android|iphone|ipad|ipod|mobile)/', $ua) === 1) {
            return '01';
        }

        return '02';
    }

    // ------------------------------------------------------------------------
    // Registro tipo "4" — Ajuste do relógio do REP (73 caracteres, campos 1 a 5 + CRC-16)
    //
    // Layout: NSR(9) + tipo"4"(1) + DH-antes-do-ajuste(24) + DH-depois-do-ajuste(24) +
    //         CPF do responsável(11) + CRC-16(4) = 73 caracteres.
    //
    // Para o REP-P SupportPONTO, este registro só existe quando um administrador declara
    // conscientemente uma mudança no relógio do servidor (ver ClockAdjustmentController /
    // ClockAdjustmentModel — migração de servidor, correção de fuso/horário etc.). Cada
    // declaração já nasce com NSR canônico da mesma sequência das marcações de ponto, o que
    // preserva a ordenação global por NSR exigida pelo item 4 do leiaute.
    // ------------------------------------------------------------------------

    /**
     * @param array $adjustments Cada item deve conter: nsr, previous_datetime,
     *                           adjusted_datetime, responsible_cpf.
     *
     * @return string[]
     */
    private function buildClockAdjustRecords(array $adjustments): array
    {
        $records = [];

        foreach ($adjustments as $adjustment) {
            $adjustment = (array) $adjustment;

            if (! isset($adjustment['nsr']) || (int) $adjustment['nsr'] < 1) {
                throw new \RuntimeException('Declaração de ajuste de relógio sem NSR canônico — exportação de AFD bloqueada por integridade.');
            }

            $responsibleCpf = $this->onlyDigits((string) ($adjustment['responsible_cpf'] ?? ''));
            if ($responsibleCpf === '' || strlen($responsibleCpf) > 11) {
                throw new \RuntimeException('Declaração de ajuste de relógio sem CPF válido do responsável — exportação de AFD bloqueada.');
            }

            $body =
                $this->padNumeric((string) (int) $adjustment['nsr'], 9)
                . self::RECORD_TYPE_CLOCK_ADJUST
                . $this->formatDateTime((string) ($adjustment['previous_datetime'] ?? ''))
                . $this->formatDateTime((string) ($adjustment['adjusted_datetime'] ?? ''))
                . $this->padNumeric($responsibleCpf, 11);

            $records[] = $body . $this->crc16Kermit($body);
        }

        return $records;
    }

    // ------------------------------------------------------------------------
    // Registro tipo "5" — Inclusão/Alteração/Exclusão de empregado no REP
    // (118 caracteres, campos 1 a 8 + CRC-16)
    //
    // Layout: NSR(9) + tipo"5"(1) + DH(24) + tipo de operação(1: "I"/"A"/"E") +
    //         CPF do empregado(12) + nome(52) + demais dados de identificação(4) +
    //         CPF do responsável(11) + CRC-16(4) = 118 caracteres.
    //
    // Para o REP-P SupportPONTO, este registro é DECLARADO automaticamente pelo próprio
    // sistema sempre que uma operação de ciclo de vida do empregado é executada — ver
    // EmployeeAfdEventRecorderService e os pontos de injeção em EmployeeController
    // (store/update), EmployeeControllerActionService (deleteEmployee/
    // setEmployeeActiveState/approveRegistration) e EmployeeChangeRequestController
    // (approve). Cada evento já nasce com NSR canônico da mesma sequência das marcações
    // de ponto, preservando a ordenação global por NSR exigida pelo leiaute.
    //
    // O campo "demais dados de identificação do empregado" (4 posições) não possui
    // definição prática aplicável ao REP-P no leiaute oficial — preenchido em branco.
    // ------------------------------------------------------------------------

    /**
     * @param array $events Cada item deve conter: nsr, operation_type ("I"/"A"/"E"),
     *                      employee_cpf, employee_name, responsible_cpf, recorded_at.
     *
     * @return string[]
     */
    private function buildEmployeeRecords(array $events): array
    {
        $records = [];

        foreach ($events as $event) {
            $records[] = $this->generateEmployeeRecord((array) $event);
        }

        return $records;
    }

    private function generateEmployeeRecord(array $event): string
    {
        if (! isset($event['nsr']) || (int) $event['nsr'] < 1) {
            throw new \RuntimeException('Evento de empregado sem NSR canônico — exportação de AFD bloqueada por integridade.');
        }

        $operationType = strtoupper(trim((string) ($event['operation_type'] ?? '')));
        if (! in_array($operationType, ['I', 'A', 'E'], true)) {
            throw new \RuntimeException('Evento de empregado com tipo de operação inválido (somente "I"/"A"/"E" são aceitos) — exportação de AFD bloqueada.');
        }

        $employeeCpf = $this->onlyDigits((string) ($event['employee_cpf'] ?? ''));
        if ($employeeCpf === '' || strlen($employeeCpf) > 12) {
            throw new \RuntimeException('Evento de empregado sem CPF válido do empregado — exportação de AFD bloqueada.');
        }

        $responsibleCpf = $this->onlyDigits((string) ($event['responsible_cpf'] ?? ''));
        if ($responsibleCpf === '' || strlen($responsibleCpf) > 11) {
            throw new \RuntimeException('Evento de empregado sem CPF válido do responsável — exportação de AFD bloqueada.');
        }

        $employeeName = (string) ($event['employee_name'] ?? '');

        $body =
            $this->padNumeric((string) (int) $event['nsr'], 9)
            . self::RECORD_TYPE_EMPLOYEE
            . $this->formatDateTime((string) ($event['recorded_at'] ?? 'now'))
            . $operationType
            . $this->padNumeric($employeeCpf, 12)
            . $this->padAlpha($employeeName, 52)
            . $this->padAlpha('', 4)
            . $this->padNumeric($responsibleCpf, 11);

        return $body . $this->crc16Kermit($body);
    }

    // ------------------------------------------------------------------------
    // Registro tipo "6" — Eventos sensíveis do REP (36 caracteres, SEM CRC-16)
    //
    // Layout: NSR(9) + tipo"6"(1) + DH(24) + código do evento(2) = 36 caracteres.
    // Nota do leiaute oficial: ao contrário dos tipos "1"/"2"/"4"/"7", o tipo "6" NÃO
    // possui campo de CRC-16 (apenas 4 campos, sem o campo de verificação).
    //
    // Para o REP-P SupportPONTO, somente os códigos "07" (disponibilidade de serviço) e
    // "08" (indisponibilidade de serviço) se aplicam — os demais (01/03/04/05/06) são
    // exclusivos de REP-C, e "02" (retorno de energia) não é detectável por software.
    //
    // DIFERENÇA-CHAVE em relação aos tipos "2"/"4": este registro é DETECTADO (não
    // declarado) por um heartbeat periódico — ver RepAvailabilityMonitorService /
    // RepHeartbeatCommand. O sistema não pode logar sua própria indisponibilidade
    // enquanto está fora do ar; a única estratégia viável é comparar execuções do
    // heartbeat e, ao notar uma lacuna, gravar o par 08 (início) / 07 (fim) com NSRs
    // canônicos consecutivos — preservando a ordenação global exigida pelo leiaute.
    // ------------------------------------------------------------------------

    /**
     * @param array $events Cada item deve conter: nsr, event_code ("07"/"08"), recorded_at.
     *
     * @return string[]
     */
    private function buildAvailabilityRecords(array $events): array
    {
        $records = [];

        foreach ($events as $event) {
            $records[] = $this->generateAvailabilityRecord((array) $event);
        }

        return $records;
    }

    private function generateAvailabilityRecord(array $event): string
    {
        if (! isset($event['nsr']) || (int) $event['nsr'] < 1) {
            throw new \RuntimeException('Evento sensível do REP sem NSR canônico — exportação de AFD bloqueada por integridade.');
        }

        // Somente "07" (disponibilidade) e "08" (indisponibilidade) se aplicam ao REP-P —
        // ver RepAvailabilityEventModel::EVENT_AVAILABLE / EVENT_UNAVAILABLE.
        $eventCode = $this->onlyDigits((string) ($event['event_code'] ?? ''));
        if (! in_array($eventCode, ['07', '08'], true)) {
            throw new \RuntimeException('Evento sensível do REP com código inválido para REP-P (somente "07"/"08" são aceitos) — exportação de AFD bloqueada.');
        }

        return
            $this->padNumeric((string) (int) $event['nsr'], 9)
            . self::RECORD_TYPE_REP_EVENT
            . $this->formatDateTime((string) ($event['recorded_at'] ?? ''))
            . $this->padNumeric($eventCode, 2);
    }

    // ------------------------------------------------------------------------
    // Registro tipo "9" — Trailer (64 caracteres, campos 1 a 8)
    // Ordem oficial das contagens: tipo 2, 3, 4, 5, 6, 7. Como este é um REP-P, não existem
    // registros do tipo "3" (exclusivo de REP-C/REP-A) — a contagem desse campo é sempre "0".
    // ------------------------------------------------------------------------
    private function generateTrailer(int $countType2, int $countType4, int $countType5, int $countType6, int $countType7): string
    {
        return
            $this->padNumeric('999999999', 9)
            . $this->padNumeric((string) $countType2, 9)
            . $this->padNumeric('0', 9)
            . $this->padNumeric((string) $countType4, 9)
            . $this->padNumeric((string) $countType5, 9)
            . $this->padNumeric((string) $countType6, 9)
            . $this->padNumeric((string) $countType7, 9)
            . self::RECORD_TYPE_TRAILER;
    }

    // ------------------------------------------------------------------------
    // Registro de Assinatura Digital (100 caracteres)
    // Para REP-P, preenchido com o texto literal padrão + espaços à direita.
    // ------------------------------------------------------------------------
    private function generateDigitalSignature(): string
    {
        return $this->padAlpha(self::DIGITAL_SIGNATURE_PLACEHOLDER, 100);
    }

    // ------------------------------------------------------------------------
    // Helpers de formatação / cálculo
    // ------------------------------------------------------------------------

    private function onlyDigits(string $value): string
    {
        return (string) preg_replace('/\D/', '', $value);
    }

    private function padNumeric(string $value, int $length): string
    {
        $digits = $this->onlyDigits($value);
        if ($digits === '') {
            $digits = '0';
        }

        // Trunca os dígitos mais significativos (preserva a parte menos significativa) caso
        // o valor exceda o tamanho do campo — nunca deveria ocorrer com dados válidos, mas
        // evita estourar o layout posicional do arquivo.
        if (strlen($digits) > $length) {
            $digits = substr($digits, -$length);
        }

        return str_pad($digits, $length, '0', STR_PAD_LEFT);
    }

    private function padAlpha(string $value, int $length): string
    {
        return str_pad(substr($value, 0, $length), $length, ' ', STR_PAD_RIGHT);
    }

    /**
     * Formato "D" do leiaute: "AAAA-MM-dd".
     */
    private function formatDate(string $value): string
    {
        $timestamp = $this->resolveTimestamp($value);

        return date('Y-m-d', $timestamp);
    }

    /**
     * Formato "DH" do leiaute: "AAAA-MM-ddThh:mm:00ZZZZZ" — segundos sempre "00";
     * ZZZZZ é o sinal seguido de HHMM do fuso horário (ex.: 2021-04-27T16:44:00-0300,
     * exemplo do próprio leiaute oficial).
     */
    private function formatDateTime(string $value): string
    {
        $timestamp = $this->resolveTimestamp($value);

        return date('Y-m-d\TH:i:00O', $timestamp);
    }

    private function resolveTimestamp(string $value): int
    {
        if ($value === '' || $value === 'now') {
            return time();
        }

        $timestamp = strtotime($value);

        return $timestamp !== false ? $timestamp : time();
    }

    /**
     * @return array{0: string, 1: string} [dataInicial, dataFinal] no formato "AAAA-MM-dd"
     */
    private function resolvePeriod(array $data): array
    {
        $timestamps = [];

        foreach ($data as $record) {
            $record = (array) $record;

            if (! empty($record['punch_time'])) {
                $timestamp = strtotime((string) $record['punch_time']);
                if ($timestamp !== false) {
                    $timestamps[] = $timestamp;
                }
            }
        }

        if (empty($timestamps)) {
            $today = date('Y-m-d');

            return [$today, $today];
        }

        return [date('Y-m-d', min($timestamps)), date('Y-m-d', max($timestamps))];
    }

    /**
     * CRC-16/KERMIT (também conhecido como CCITT-TRUE / CRC-16-CCITT refletido), exigido pelo
     * item 8 do leiaute para registros tipo "1" e "2" quando gerados por REP-A ou REP-P.
     * Polinômio 0x1021 refletido (0x8408), valor inicial 0x0000, sem XOR final.
     *
     * Verificação oficial (item 8 do leiaute): CRC16("123456789") deve resultar em 0x2189 —
     * coberto por TXTAFDBuilderTest.
     *
     * @return string Representação hexadecimal de 4 caracteres, maiúscula, sem o prefixo "0x".
     */
    private function crc16Kermit(string $data): string
    {
        $crc    = 0x0000;
        $length = strlen($data);

        for ($i = 0; $i < $length; $i++) {
            $crc ^= ord($data[$i]);

            for ($bit = 0; $bit < 8; $bit++) {
                if (($crc & 0x0001) !== 0) {
                    $crc = ($crc >> 1) ^ 0x8408;
                } else {
                    $crc >>= 1;
                }
            }
        }

        return strtoupper(str_pad(dechex($crc & 0xFFFF), 4, '0', STR_PAD_LEFT));
    }
}
