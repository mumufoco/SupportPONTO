<?php

namespace App\Services\Timesheet;

use PhpOffice\PhpSpreadsheet\Spreadsheet;
use PhpOffice\PhpSpreadsheet\Writer\Xlsx;
use PhpOffice\PhpSpreadsheet\Style\Alignment;
use PhpOffice\PhpSpreadsheet\Style\Border;
use PhpOffice\PhpSpreadsheet\Style\Color;
use PhpOffice\PhpSpreadsheet\Style\Fill;

/**
 * Generates downloadable Excel and PDF exports for the Timesheet Balance page.
 * Uses PhpSpreadsheet for Excel and TCPDF for PDF — both already installed.
 */
class TimesheetBalanceExportService
{
    private const GREEN  = '1A7A4A';
    private const RED    = 'C0392B';
    private const BLUE   = '1A4A7A';
    private const LGRAY  = 'F2F4F7';
    private const DGRAY  = '374151';

    // ── Excel ─────────────────────────────────────────────────────────────────

    public function buildExcel(object $employee, array $records, array $balance, array $statistics, int $days): array
    {
        $spreadsheet = new Spreadsheet();
        $spreadsheet->getProperties()
            ->setTitle('Saldo de Horas')
            ->setSubject($employee->name ?? '')
            ->setCreator('SupportPONTO');

        $this->buildSummarySheet($spreadsheet->getActiveSheet(), $employee, $balance, $statistics, $days);

        $detail = $spreadsheet->createSheet();
        $detail->setTitle('Registros Detalhados');
        $this->buildDetailSheet($detail, $records);

        $filename = 'saldo_horas_' . ($employee->id ?? 0) . '_' . date('Y-m-d') . '.xlsx';
        $writer   = new Xlsx($spreadsheet);

        ob_start();
        $writer->save('php://output');
        $content = ob_get_clean();

        return ['content' => $content, 'filename' => $filename];
    }

    private function buildSummarySheet($sheet, object $employee, array $balance, array $statistics, int $days): void
    {
        $sheet->setTitle('Resumo');

        // Title
        $sheet->mergeCells('A1:H1');
        $sheet->setCellValue('A1', 'RELATÓRIO DE SALDO DE HORAS — ' . strtoupper($employee->name ?? ''));
        $sheet->getStyle('A1')->applyFromArray([
            'font'      => ['bold' => true, 'size' => 14, 'color' => ['argb' => 'FF' . self::DGRAY]],
            'fill'      => ['fillType' => Fill::FILL_SOLID, 'startColor' => ['argb' => 'FF' . self::LGRAY]],
            'alignment' => ['horizontal' => Alignment::HORIZONTAL_CENTER],
        ]);
        $sheet->getRowDimension(1)->setRowHeight(28);

        // Meta
        $sheet->setCellValue('A2', 'Período:');
        $sheet->setCellValue('B2', 'Últimos ' . $days . ' dias (até ' . date('d/m/Y') . ')');
        $sheet->setCellValue('A3', 'Departamento:');
        $sheet->setCellValue('B3', $employee->department ?? '-');
        $sheet->setCellValue('A4', 'Cargo:');
        $sheet->setCellValue('B4', $employee->position ?? '-');
        $sheet->setCellValue('E2', 'Gerado em:');
        $sheet->setCellValue('F2', date('d/m/Y H:i'));
        foreach (['A2','A3','A4','E2'] as $c) {
            $sheet->getStyle($c)->getFont()->setBold(true);
        }

        // Blank row
        $sheet->getRowDimension(5)->setRowHeight(6);

        // Balance KPIs header
        $kpiHeaders = ['Horas Extras', 'Horas Devidas', 'Saldo', 'Dias Trabalhados', 'Dias Incompletos', 'Média Diária'];
        $kpiValues  = [
            '+' . number_format($balance['extra'],    2) . 'h',
            '-' . number_format($balance['owed'],     2) . 'h',
            ($balance['balance'] >= 0 ? '+' : '') . number_format($balance['balance'], 2) . 'h',
            $statistics['total_days'],
            $statistics['incomplete_days'],
            number_format($statistics['avg_worked'], 2) . 'h',
        ];
        $kpiColors  = [self::GREEN, self::RED, $balance['balance'] >= 0 ? self::GREEN : self::RED, self::BLUE, self::BLUE, self::BLUE];
        $cols       = ['A','B','C','D','E','F'];

        foreach ($cols as $i => $col) {
            $sheet->mergeCells("{$col}6:{$col}6");
            $sheet->setCellValue("{$col}6", $kpiHeaders[$i]);
            $sheet->getStyle("{$col}6")->applyFromArray([
                'font'      => ['bold' => true, 'size' => 9, 'color' => ['argb' => 'FFFFFFFF']],
                'fill'      => ['fillType' => Fill::FILL_SOLID, 'startColor' => ['argb' => 'FF' . $kpiColors[$i]]],
                'alignment' => ['horizontal' => Alignment::HORIZONTAL_CENTER],
            ]);
            $sheet->setCellValue("{$col}7", $kpiValues[$i]);
            $sheet->getStyle("{$col}7")->applyFromArray([
                'font'      => ['bold' => true, 'size' => 13, 'color' => ['argb' => 'FF' . $kpiColors[$i]]],
                'alignment' => ['horizontal' => Alignment::HORIZONTAL_CENTER],
            ]);
            $sheet->getColumnDimension($col)->setWidth(18);
            $sheet->getRowDimension(7)->setRowHeight(24);
        }

        foreach (['A6:F6', 'A7:F7'] as $range) {
            $sheet->getStyle($range)->getBorders()->getAllBorders()->setBorderStyle(Border::BORDER_THIN);
        }
    }

    private function buildDetailSheet($sheet, array $records): void
    {
        $headers = ['Data', 'Dia', 'Entrada', 'Saída', 'Intervalo (h)', 'Trabalhado (h)', 'Esperado (h)', 'Extras (h)', 'Devidas (h)', 'Status'];
        $colMap   = ['A','B','C','D','E','F','G','H','I','J'];
        $widths   = [13, 12, 10, 10, 14, 16, 14, 12, 12, 14];

        foreach ($colMap as $i => $col) {
            $sheet->setCellValue("{$col}1", $headers[$i]);
            $sheet->getColumnDimension($col)->setWidth($widths[$i]);
        }
        $sheet->getStyle('A1:J1')->applyFromArray([
            'font'      => ['bold' => true, 'color' => ['argb' => 'FFFFFFFF']],
            'fill'      => ['fillType' => Fill::FILL_SOLID, 'startColor' => ['argb' => 'FF' . self::BLUE]],
            'alignment' => ['horizontal' => Alignment::HORIZONTAL_CENTER],
        ]);
        $sheet->setAutoFilter('A1:J1');

        $row = 2;
        foreach ($records as $record) {
            $dateStr  = (string) ($record->date ?? '');
            $status   = 'OK';
            if (!empty($record->incomplete))  $status = 'Incompleto';
            elseif (!empty($record->justified)) $status = 'Justificado';

            $sheet->fromArray([
                $dateStr ? date('d/m/Y', strtotime($dateStr)) : '-',
                $dateStr ? ucfirst(strftime('%A', strtotime($dateStr))) : '-',
                $record->first_punch ?? '-',
                $record->last_punch  ?? '-',
                number_format((float)($record->total_interval ?? 0), 2),
                number_format((float)($record->total_worked   ?? 0), 2),
                number_format((float)($record->expected       ?? 0), 2),
                number_format((float)($record->extra          ?? 0), 2),
                number_format((float)($record->owed           ?? 0), 2),
                $status,
            ], null, "A{$row}");

            // Color rows
            if (!empty($record->incomplete)) {
                $sheet->getStyle("A{$row}:J{$row}")->getFill()->setFillType(Fill::FILL_SOLID)->getStartColor()->setARGB('FFFFF3CD');
            } elseif ((float)($record->extra ?? 0) > 0) {
                $sheet->getStyle("H{$row}")->getFont()->getColor()->setARGB('FF' . self::GREEN);
                $sheet->getStyle("H{$row}")->getFont()->setBold(true);
            }
            if ((float)($record->owed ?? 0) > 0) {
                $sheet->getStyle("I{$row}")->getFont()->getColor()->setARGB('FF' . self::RED);
                $sheet->getStyle("I{$row}")->getFont()->setBold(true);
            }
            $row++;
        }
    }

    // ── PDF ──────────────────────────────────────────────────────────────────

    public function buildPdf(object $employee, array $records, array $balance, array $statistics, int $days): array
    {
        $pdf = new \TCPDF('L', 'mm', 'A4', true, 'UTF-8', false);
        $pdf->SetCreator('SupportPONTO');
        $pdf->SetAuthor('SupportPONTO');
        $pdf->SetTitle('Saldo de Horas — ' . ($employee->name ?? ''));
        $pdf->SetMargins(12, 8, 12);
        $pdf->SetHeaderMargin(5);
        $pdf->SetFooterMargin(8);
        $pdf->setPrintHeader(false);
        $pdf->setPrintFooter(true);
        $pdf->SetAutoPageBreak(true, 14);
        $pdf->SetFont('helvetica', '', 9);

        $pdf->AddPage();

        $html = $this->buildPdfHtml($employee, $records, $balance, $statistics, $days);
        $pdf->writeHTML($html, true, false, true, false, '');

        $filename = 'saldo_horas_' . ($employee->id ?? 0) . '_' . date('Y-m-d') . '.pdf';
        $content  = $pdf->Output($filename, 'S');

        return ['content' => $content, 'filename' => $filename];
    }

    private function buildPdfHtml(object $employee, array $records, array $balance, array $statistics, int $days): string
    {
        $balValue = $balance['balance'] ?? 0;
        $balColor = $balValue >= 0 ? '#1A7A4A' : '#C0392B';
        $balText  = ($balValue >= 0 ? '+' : '') . number_format($balValue, 2) . 'h';

        $h  = '<style>';
        $h .= 'h1{font-size:16pt;font-weight:bold;color:#1A4A7A;margin:0 0 2mm 0}';
        $h .= 'h2{font-size:10pt;font-weight:bold;color:#374151;margin:4mm 0 2mm 0;border-bottom:0.5px solid #ccc;padding-bottom:1mm}';
        $h .= '.meta{font-size:8pt;color:#6b7280;margin-bottom:4mm}';
        $h .= 'table{border-collapse:collapse;width:100%;margin-bottom:4mm}';
        $h .= 'th{background-color:#1A4A7A;color:#fff;font-size:8pt;padding:2mm 3mm;text-align:center}';
        $h .= 'td{font-size:8pt;padding:1.5mm 3mm;border-bottom:0.3px solid #e5e7eb}';
        $h .= '.kpi-box{background:#f8fafc;border:0.5px solid #e5e7eb;padding:3mm;text-align:center}';
        $h .= '.kpi-val{font-size:14pt;font-weight:bold}';
        $h .= '.kpi-lbl{font-size:7pt;color:#6b7280}';
        $h .= '.ok{color:#1A7A4A}.bad{color:#C0392B}.warn{color:#d97706}';
        $h .= '.row-inc{background:#fffbeb}.row-ok{background:#f0fdf4}';
        $h .= '</style>';

        // Header
        $h .= '<h1>Relatório de Saldo de Horas</h1>';
        $h .= '<div class="meta">';
        $h .= '<b>Funcionário:</b> ' . esc($employee->name ?? '-') . ' &nbsp;|&nbsp; ';
        $h .= '<b>Departamento:</b> ' . esc($employee->department ?? '-') . ' &nbsp;|&nbsp; ';
        $h .= '<b>Cargo:</b> ' . esc($employee->position ?? '-') . '<br>';
        $h .= '<b>Período:</b> Últimos ' . $days . ' dias (até ' . date('d/m/Y') . ') &nbsp;|&nbsp; ';
        $h .= '<b>Gerado em:</b> ' . date('d/m/Y H:i') . '</div>';

        // KPI row
        $kpis = [
            ['label' => 'Horas Extras',    'val' => '+' . number_format($balance['extra'], 2) . 'h', 'cls' => 'ok'],
            ['label' => 'Horas Devidas',   'val' => '-' . number_format($balance['owed'], 2) . 'h',  'cls' => 'bad'],
            ['label' => 'Saldo Total',     'val' => $balText, 'cls' => $balValue >= 0 ? 'ok' : 'bad'],
            ['label' => 'Dias Trabalhados','val' => $statistics['total_days'],       'cls' => ''],
            ['label' => 'Dias Incompletos','val' => $statistics['incomplete_days'],  'cls' => $statistics['incomplete_days'] > 0 ? 'warn' : ''],
            ['label' => 'Média Diária',    'val' => number_format($statistics['avg_worked'], 2) . 'h', 'cls' => ''],
        ];
        $h .= '<table><tr>';
        foreach ($kpis as $k) {
            $h .= '<td class="kpi-box"><div class="kpi-val ' . $k['cls'] . '">' . $k['val'] . '</div><div class="kpi-lbl">' . $k['label'] . '</div></td>';
        }
        $h .= '</tr></table>';

        // Detail table
        $h .= '<h2>Registros Detalhados</h2>';
        $h .= '<table>';
        $h .= '<thead><tr>';
        foreach (['Data','Dia','Entrada','Saída','Intervalo','Trabalhado','Esperado','Extras','Devidas','Status'] as $col) {
            $h .= "<th>{$col}</th>";
        }
        $h .= '</tr></thead><tbody>';

        foreach ($records as $rec) {
            $dateStr = (string)($rec->date ?? '');
            $worked  = (float)($rec->total_worked ?? 0);
            $extra   = (float)($rec->extra ?? 0);
            $owed    = (float)($rec->owed ?? 0);
            $inc     = !empty($rec->incomplete);
            $just    = !empty($rec->justified);

            $status     = $inc ? '<span class="warn">Incompleto</span>' : ($just ? '<span class="ok">Justificado</span>' : '<span class="ok">OK</span>');
            $extraFmt   = $extra > 0 ? '<span class="ok">+' . number_format($extra, 2) . 'h</span>' : '-';
            $owedFmt    = $owed  > 0 ? '<span class="bad">-' . number_format($owed, 2) . 'h</span>'  : '-';
            $rowCls     = $inc ? 'row-inc' : ($extra > 0 ? 'row-ok' : '');

            $dayName = $dateStr ? date('D', strtotime($dateStr)) : '-';
            $dayPt   = ['Mon'=>'Seg','Tue'=>'Ter','Wed'=>'Qua','Thu'=>'Qui','Fri'=>'Sex','Sat'=>'Sáb','Sun'=>'Dom'][$dayName] ?? $dayName;

            $h .= "<tr class=\"{$rowCls}\">";
            $h .= '<td>' . ($dateStr ? date('d/m/Y', strtotime($dateStr)) : '-') . '</td>';
            $h .= '<td>' . $dayPt . '</td>';
            $h .= '<td>' . ($rec->first_punch ?? '-') . '</td>';
            $h .= '<td>' . ($rec->last_punch ?? '-') . '</td>';
            $h .= '<td>' . number_format((float)($rec->total_interval ?? 0), 2) . 'h</td>';
            $h .= '<td><b>' . number_format($worked, 2) . 'h</b></td>';
            $h .= '<td>' . number_format((float)($rec->expected ?? 0), 2) . 'h</td>';
            $h .= '<td>' . $extraFmt . '</td>';
            $h .= '<td>' . $owedFmt . '</td>';
            $h .= '<td>' . $status . '</td>';
            $h .= '</tr>';
        }

        $h .= '</tbody></table>';
        return $h;
    }
}
