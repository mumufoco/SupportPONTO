<script <?= csp_script_nonce_attr() ?>>
(() => {
    const xEsc = s => String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));

    function showFeedback(html, type) {
        const icons = {success:'check-circle-fill',danger:'x-circle-fill',warning:'exclamation-triangle-fill',info:'info-circle-fill'};
        const el = document.getElementById('enrollFeedback');
        if (!el) return;
        el.innerHTML = `<div class="alert alert-${type} d-flex gap-2 align-items-start"><i class="bi bi-${icons[type]??'info-circle-fill'} flex-shrink-0 mt-1"></i><div>${html}</div></div>`;
        el.scrollIntoView({behavior:'smooth',block:'nearest'});
    }
    function hideFeedback() { const el=document.getElementById('enrollFeedback'); if(el) el.innerHTML=''; }

    window.spSelectMode = function(mode) {
        document.getElementById('modeUsb').style.display    = mode==='usb'    ? '' : 'none';
        document.getElementById('modeMobile').style.display = mode==='mobile' ? '' : 'none';
        document.getElementById('btnModeUsb').classList.toggle('is-selected', mode==='usb');
        document.getElementById('btnModeMobile').classList.toggle('is-selected', mode==='mobile');
        hideFeedback();
    };

    // Finger diagram
    const fingerNames = {
        right_thumb:'Polegar direito',right_index:'Indicador direito',right_middle:'Medio direito',
        right_ring:'Anelar direito',right_pinky:'Minimo direito',left_thumb:'Polegar esquerdo',
        left_index:'Indicador esquerdo',left_middle:'Medio esquerdo',left_ring:'Anelar esquerdo',left_pinky:'Minimo esquerdo',
    };
    const hiddenFinger = document.getElementById('hiddenFinger');
    const fingerLabel  = document.getElementById('fingerSelectedLabel');
    const allBtns      = document.querySelectorAll('.sp-finger-btn:not([disabled])');

    function selectFinger(btn) {
        allBtns.forEach(b => b.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        if (hiddenFinger) hiddenFinger.value = btn.dataset.finger;
        if (fingerLabel)  fingerLabel.innerHTML = 'Selecionado: <strong>' + xEsc(fingerNames[btn.dataset.finger]??btn.dataset.finger) + '</strong>';
    }
    allBtns.forEach(b => b.addEventListener('click', () => selectFinger(b)));
    const defBtn = document.querySelector('.sp-finger-btn[data-finger="right_index"]:not([disabled])');
    if (defBtn) selectFinger(defBtn);

    window.spResetUsb = function() {
        if (hiddenFinger) hiddenFinger.value = 'right_index';
        allBtns.forEach(b => b.classList.remove('is-selected'));
        if (defBtn) defBtn.classList.add('is-selected');
        if (fingerLabel) fingerLabel.innerHTML = 'Selecionado: <strong>Indicador direito</strong>';
        hideFeedback();
    };

    // USB form
    const formUsb = document.getElementById('formUsb');
    if (formUsb) {
        formUsb.addEventListener('submit', async e => {
            e.preventDefault();
            const btn = formUsb.querySelector('[type=submit]'), orig = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Cadastrando...';
            showFeedback('Enviando e criptografando template biometrico...','info');
            try {
                const resp = await spFetch('<?= site_url('biometric/fingerprint/enroll') ?>',
                    {method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'},body:new FormData(formUsb)});
                const data = await resp.json();
                if (data.success) {
                    showFeedback(xEsc(data.message||'Digital cadastrada com sucesso!'),'success');
                    formUsb.reset(); spResetUsb();
                    setTimeout(()=>location.reload(),1500);
                } else {
                    showFeedback(xEsc(data.message||'Erro ao cadastrar. Verifique os dados e tente novamente.'),'danger');
                }
            } catch { showFeedback('Falha de comunicacao com o servidor. Verifique sua conexao e tente novamente.','danger'); }
            btn.disabled=false; btn.innerHTML=orig;
        });
    }

    // ── Camera / image capture (mobile mode) ──────────
    function setMobileStatus(html, type) {
        const el = document.getElementById('mobileStatus');
        if (el) el.innerHTML = `<div class="alert alert-${type} py-2 small">${html}</div>`;
    }

    function handleImageFile(file) {
        if (!file || !file.type.startsWith('image/')) {
            setMobileStatus('Arquivo invalido. Selecione uma imagem (JPEG ou PNG).', 'warning');
            return;
        }
        if (file.size > 10 * 1024 * 1024) {
            setMobileStatus('Imagem muito grande. O limite e 10 MB.', 'warning');
            return;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
            const preview = document.getElementById('imgPreview');
            const wrap    = document.getElementById('imgPreviewWrap');
            const info    = document.getElementById('imgPreviewInfo');
            const sendBtn = document.getElementById('btnSendImage');
            if (preview) preview.src = e.target.result;
            if (wrap)    wrap.style.display = '';
            if (info)    info.textContent = `${file.name} — ${(file.size/1024).toFixed(0)} KB`;
            if (sendBtn) sendBtn.style.display = '';
            setMobileStatus('<i class="bi bi-check me-1"></i>Imagem carregada. Confirme o dedo e clique em "Processar".', 'info');
        };
        reader.onerror = () => setMobileStatus('Erro ao ler o arquivo. Tente novamente.', 'danger');
        reader.readAsDataURL(file);
    }

    ['inputCameraCapture', 'inputFileUpload'].forEach(id => {
        document.getElementById(id)?.addEventListener('change', e => {
            const file = e.target.files?.[0];
            if (file) handleImageFile(file);
        });
    });

    document.getElementById('btnSendImage')?.addEventListener('click', async () => {
        const finger  = document.getElementById('fingerMobile')?.value;
        const preview = document.getElementById('imgPreview');
        if (!finger)  { setMobileStatus('Selecione o dedo antes de continuar.', 'warning'); return; }
        if (!preview?.src || preview.src === window.location.href) {
            setMobileStatus('Tire ou carregue uma foto primeiro.', 'warning'); return;
        }

        const btn = document.getElementById('btnSendImage');
        const orig = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Processando digital...';
        setMobileStatus('<i class="bi bi-cpu me-1"></i>Extraindo minutias da imagem...', 'info');

        try {
            const csrfVal = document.querySelector('input[name="<?= csrf_token() ?>"]')?.value ?? '';
            const fd = new FormData();
            fd.append('employee_id', '<?= $employeeId ?>');
            fd.append('finger', finger);
            fd.append('quality', '0.75');
            fd.append('image_base64', preview.src);
            fd.append('<?= csrf_token() ?>', csrfVal);

            const resp = await spFetch('<?= site_url('biometric/fingerprint/enroll-from-image') ?>', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: fd,
            });
            const data = await resp.json();

            if (data.success) {
                const minutiae = data.minutiae_count ? ` (${data.minutiae_count} minutias detectadas)` : '';
                setMobileStatus(`<i class="bi bi-check-circle-fill me-1"></i>Digital cadastrada com sucesso!${minutiae} Recarregando...`, 'success');
                showFeedback(xEsc(data.message || 'Digital cadastrada via foto com sucesso!'), 'success');
                setTimeout(() => location.reload(), 1800);
            } else {
                setMobileStatus('<i class="bi bi-x-circle-fill me-1"></i>' + xEsc(data.message || 'Nao foi possivel processar a imagem.'), 'danger');
                btn.disabled = false;
                btn.innerHTML = orig;
            }
        } catch {
            setMobileStatus('Falha de comunicacao com o servidor. Verifique sua conexao e tente novamente.', 'danger');
            btn.disabled = false;
            btn.innerHTML = orig;
        }
    });

    // QR Code
    document.getElementById('btnGenQR')?.addEventListener('click', () => {
        const url = '<?= site_url('biometric/fingerprint/enroll/' . $employeeId) ?>';
        const container = document.getElementById('qrContainer');
        const input     = document.getElementById('qrLink');
        container.innerHTML = ''; input.value = url;
        if (typeof QRCode !== 'undefined') {
            new QRCode(container,{text:url,width:160,height:160,colorDark:'#1a1a2e',colorLight:'#ffffff'});
        } else {
            container.innerHTML = '<p class="text-muted small">Biblioteca QRCode nao disponivel.</p>';
        }
        document.getElementById('qrResult').style.display='';
        document.getElementById('btnGenQR').innerHTML='<i class="bi bi-arrow-clockwise me-2"></i>Gerar novo QR Code';
    });

    window.spCopyQR = function() {
        const inp=document.getElementById('qrLink');
        navigator.clipboard?.writeText(inp.value).then(()=>{
            const b=inp.nextElementSibling,o=b.innerHTML;
            b.innerHTML='<i class="bi bi-check2"></i>';
            setTimeout(()=>b.innerHTML=o,1800);
        }).catch(()=>{inp.select();document.execCommand('copy');});
    };

    // Delete template
    let pendingId=null;
    const modalDel = new bootstrap.Modal(document.getElementById('modalDelete'));
    document.querySelectorAll('.js-del-tpl').forEach(btn=>{
        btn.addEventListener('click',()=>{
            pendingId=btn.dataset.id;
            document.getElementById('delFingerName').textContent=btn.dataset.finger;
            modalDel.show();
        });
    });
    document.getElementById('btnConfirmDelete')?.addEventListener('click', async()=>{
        if (!pendingId) return;
        const btn=document.getElementById('btnConfirmDelete'),orig=btn.innerHTML;
        btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Excluindo...';
        try {
            const csrfVal=document.querySelector('input[name="<?= csrf_token() ?>"]')?.value??'';
            const resp=await spFetch(`<?= site_url('biometric/fingerprint/') ?>${pendingId}`,{
                method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'},
                body:new URLSearchParams({_method:'DELETE','<?= csrf_token() ?>':csrfVal}),
            });
            const data=await resp.json();
            modalDel.hide();
            showFeedback(xEsc(data.message||'Operacao concluida.'),data.success?'success':'danger');
            if(data.success) setTimeout(()=>location.reload(),1200);
        } catch { showFeedback('Falha ao excluir. Tente novamente.','danger'); }
        btn.disabled=false;btn.innerHTML=orig;
    });
})();
</script>
<script <?= csp_script_nonce_attr() ?> src="<?= site_url('assets/js/qrcode.min.js') ?>"></script>
<?= $this->endSection() ?>
